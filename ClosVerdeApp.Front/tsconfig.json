{
	"extends": "@elyspio/vite-eslint-config/tsconfig.json",
	"compilerOptions": {
		"module": "esnext",
		"moduleResolution": "bundler",
		"downlevelIteration": null,
		"paths": {
			"@/*": ["./src/*"],
			"@apis/*": ["./src/core/apis/*"],
			"@services/*": ["./src/core/services/*"]
		},
		"types": ["vite/client"]
	},
	"include": ["src", "vite.config.ts", "scripts"]
}
