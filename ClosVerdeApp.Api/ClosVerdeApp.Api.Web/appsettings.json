{
	"ConnectionStrings": {
		"MongoDB": "mongodb://localhost:27017/clos-verde-app"
	},
	"Keycloak": {
		"Authority": "https://auth.elyspio.fr/realms/clos-verde",
		"ClientId": "cv_dev-front",
		"Admin": {
			"ClientId": "cv_dev-api",
			"TokenEndpoint": "https://auth.elyspio.fr/realms/clos-verde/protocol/openid-connect/token",
			"UsersEndpoint": "https://auth.elyspio.fr/admin/realms/clos-verde/users",
			"CacheTtl": "00:05:00"
		}
	},
	"Reservation": {
		"ValidationDelay": "01:00:00",
		"ScannerInterval": "00:01:00"
	},
	"AllowedHosts": "*",
	"Serilog": {
		"MinimumLevel": {
			"Default": "Debug",
			"Override": {
				"Microsoft": "Debug",
				"Microsoft.Hosting.Lifetime": "Information",
				"Microsoft.AspNetCore.Hosting.Diagnostics": "Information",
				"System": "Warning"
			}
		},
		"Using": [
			"Serilog.Sinks.Console"
		],
		"WriteTo": [
			{
				"Name": "Console",
				"Args": {
					"theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
					"outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level}] {SourceContext:l} -- {Message}{NewLine}{Exception}"
				}
			}
		],
		"Enrich": [
			"WithExceptionDetails"
		]
	},
	"OpenTelemetry": {
		"CollectorUri": "http://localhost:4317",
		"Debug": false,
		"Service": "clos-verde-app-api"
	}
}
